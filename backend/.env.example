# Database Configuration
# Local: postgresql://postgres:P@ssw0rd@localhost:5432/homecare_matching
# Railway: Get from Railway env vars
DATABASE_URL=postgresql://postgres:P@ssw0rd@localhost:5432/homecare_matching

# Server Configuration
NODE_ENV=development
PORT=6005

# JWT Configuration (for token signing)
JWT_SECRET=your_jwt_secret_here_change_in_production

# Email Configuration (Gmail with App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SENDER_EMAIL=your_email@gmail.com
SENDER_NAME=Homecare Matching

# OTP Configuration
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6

# Worker Configuration
WORKER_POLL_INTERVAL=15000
WORKER_ENABLED=true

# Notifications
NOTIFICATION_POLL_INTERVAL=5000
NOTIFICATION_MAX_RETRY_ATTEMPTS=5# Email Configuration (for real implementation)
