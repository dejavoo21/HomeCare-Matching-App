{
  "name": "homecare-matching-app-backend",
  "version": "1.0.0",
  "description": "Healthcare professional matching platform - Backend",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "migrate": "ts-node src/migrations/runner.ts",
    "seed": "ts-node src/scripts/seed.ts",
    "worker": "ts-node-dev --respawn src/jobs/dispatch.worker.ts"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "fhir": "^4.12.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^6.10.1",
    "pg": "^8.11.1",
    "prom-client": "^15.1.3",
    "speakeasy": "^2.0.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.3.1",
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.10.7",
    "@types/speakeasy": "^2.0.10",
    "@types/uuid": "^9.0.2",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.3"
  }
}
